model Notification {
    id     String  @id @default(uuid())
    title  String
    body   String
    isRead Boolean @default(false)

    receiverUserId     String?
    receiverWorkshopId String?

    triggeredById String?
    jobId         String?
    bookingId     String?
    invoiceId     String?

    eventType String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model ChatNotification {
    id            String   @id @default(uuid())
    chatRoomId    String
    messageId     String
    triggeredById String? // sender
    title         String?
    body          String?
    isRead        Boolean  @default(false)
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
}
