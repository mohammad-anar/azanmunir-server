// CHAT

model Chat {
    id        String   @id @default(uuid())
    jobId     String
    senderId  String
    message   String
    files     String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    job    Job  @relation(fields: [jobId], references: [id])
    sender User @relation(fields: [senderId], references: [id])
}